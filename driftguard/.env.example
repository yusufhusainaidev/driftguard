# ─────────────────────────────────────────
# DriftGuard Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env and fill in values
# NEVER commit .env to git

# PostgreSQL
POSTGRES_DB=driftguard
POSTGRES_USER=driftguard_user
POSTGRES_PASSWORD=driftguard_pass

# Redis
REDIS_PASSWORD=redis_pass

# Backend
SECRET_KEY=driftguard_secret_key_change_in_prod

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Drift Detection Thresholds
PSI_THRESHOLD=0.2
KS_THRESHOLD=0.05
ACCURACY_DROP_THRESHOLD=0.05

# Retraining Config
MIN_RETRAIN_SAMPLES=500
RETRAIN_IMPROVEMENT_MARGIN=0.01
